# ----------------------------------------------------------------------
# iNGEN — waitlist environment variables
# Copy this file to .env.local and fill in the values you need.
# .env.local is gitignored, so secrets stay on your machine.
# ----------------------------------------------------------------------

# REQUIRED for forwarding signups to your Gmail.
# Sign up free at https://resend.com (3000 emails/month included).
# After signing up, create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional. Where the "From" address shows on forwarded emails.
# The default below works out of the box once you have a Resend account.
# To send from your own domain, verify it at https://resend.com/domains
# and set this to "iNGEN Waitlist <waitlist@yourdomain.com>".
# RESEND_FROM_EMAIL="iNGEN Waitlist <onboarding@resend.dev>"

# Optional. Override the destination Gmail address.
# Defaults to adidogra07@gmail.com.
# WAITLIST_TO_EMAIL=adidogra07@gmail.com

# OPTIONAL but required for the "Continue with Google" button.
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create credentials -> OAuth client ID -> Web application
# 3. Add authorized JavaScript origins:
#       http://localhost:3000
#       http://localhost:3002
#       https://your-production-domain.com
# 4. Copy the client ID here. It is exposed to the browser by design.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
